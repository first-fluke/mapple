# --- Database ---
# PostgreSQL via asyncpg driver. In prod, point to Cloud SQL via Unix socket
# or private IP, e.g. postgresql+asyncpg://user:pass@/dbname?host=/cloudsql/...
DATABASE_URL=postgresql+asyncpg://globe:globe@localhost:5432/globe_crm

# --- Redis ---
# Used for rate limiting and ephemeral state. Cloud Memorystore in prod.
REDIS_URL=redis://localhost:6379/0

# --- Object storage (MinIO local / GCS-compatible in prod) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# --- Rate limiting ---
# Per-IP request budget for /auth/* and /export/* routers.
AUTH_RATE_LIMIT=10
AUTH_RATE_WINDOW=60
