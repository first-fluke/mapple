# --- Runtime ---
ENV=dev                         # dev | prod. Toggles /docs exposure
CORS_ALLOW_ORIGINS=http://localhost:3000   # comma-separated list of web origins

# --- Database ---
# Runtime URL: Supabase Supavisor (transaction-mode pooler, port 6543) in prod,
# direct localhost in dev. asyncpg statement caches are disabled in code so the
# pooler doesn't choke on prepared statement collisions.
DATABASE_URL=postgresql+asyncpg://globe:globe@localhost:5432/globe_crm

# Migration URL: Supabase direct connection (port 5432) in prod, same as
# DATABASE_URL in dev. alembic env.py prefers this when set.
# MIGRATION_DATABASE_URL=postgresql+asyncpg://postgres:<pw>@db.<ref>.supabase.co:5432/postgres

# --- Redis (Upstash in prod, local docker in dev) ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (MinIO local / Backblaze B2 in prod, both S3-compatible) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
# In prod set MINIO_ENDPOINT=s3.<region>.backblazeb2.com, MINIO_SECURE=true,
# and use a B2 application key as access/secret.

# --- Rate limiting ---
# Per-IP request budget for /auth/* and /export/* routers.
AUTH_RATE_LIMIT=10
AUTH_RATE_WINDOW=60

# --- Auth (FastAPI Authlib + JWS) ---
# Random 32+ char secret for HS256 JWT signing. Rotate via JWT_SIGNING_KEY_NEXT
# (zero-downtime: verify accepts both, sign uses NEXT once promoted).
JWT_SIGNING_KEY=change-me-to-a-strong-random-32char-or-longer-secret
JWT_ACCESS_TTL_SECONDS=1800     # 30 min access token
JWT_REFRESH_TTL_SECONDS=2592000 # 30 day refresh token

# OAuth provider client IDs/secrets. Set redirect URI in each provider console
# to https://api.<domain>/auth/callback/{provider}.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Apple sign-in is task L11 — placeholder vars below.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=              # multi-line PEM (escape \n or use file path)

# Public base URLs — used by /auth/callback to compute redirect_uri and the
# post-auth redirect with access/refresh in the URL fragment.
API_BASE_URL=http://localhost:8000
WEB_APP_URL=http://localhost:3000
