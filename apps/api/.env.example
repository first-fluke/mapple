# --- Runtime ---
ENV=dev                         # dev | prod. Toggles /docs exposure
CORS_ALLOW_ORIGINS=http://localhost:11000   # comma-separated list of web origins

# --- Database ---
# Runtime URL: Supabase Supavisor (transaction-mode pooler, port 6543) in prod,
# direct localhost in dev. asyncpg statement caches are disabled in code so the
# pooler doesn't choke on prepared statement collisions.
DATABASE_URL=postgresql+asyncpg://globe:globe@localhost:11432/globe_crm

# Migration URL: Supabase direct connection (port 5432) in prod, same as
# DATABASE_URL in dev. alembic env.py prefers this when set.
# MIGRATION_DATABASE_URL=postgresql+asyncpg://postgres:<pw>@db.<ref>.supabase.co:5432/postgres

# --- Redis (Upstash in prod, local docker in dev) ---
REDIS_URL=redis://localhost:11379/0

# --- Object storage (MinIO local / Backblaze B2 in prod, both S3-compatible) ---
MINIO_ENDPOINT=localhost:11900
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
# In prod set MINIO_ENDPOINT=s3.<region>.backblazeb2.com, MINIO_SECURE=true,
# and use a B2 application key as access/secret.

# --- Rate limiting ---
# Per-IP request budget for /auth/* and /export/* routers.
AUTH_RATE_LIMIT=10
AUTH_RATE_WINDOW=60

# Per-user (token-keyed) request budget for data routers:
# contacts, meetings, experiences, organizations, tags, graph, globe, geocoding, imports.
DATA_RATE_LIMIT=120             # requests per DATA_RATE_WINDOW seconds
DATA_RATE_WINDOW=60             # window size in seconds

# --- Auth (FastAPI Authlib + JWS) ---
# Random 32+ char secret for HS256 JWT signing. Tokens carry kid='current'.
# Zero-downtime rotation:
#   1. Set JWT_SIGNING_KEY_NEXT alongside the primary; verify accepts both.
#   2. Wait JWT_ACCESS_TTL_SECONDS so all in-flight access tokens expire.
#   3. Promote NEXT -> primary, drop NEXT, restart.
JWT_SIGNING_KEY=change-me-to-a-strong-random-32char-or-longer-secret
JWT_SIGNING_KEY_NEXT=
JWT_ACCESS_TTL_SECONDS=1800     # 30 min access token
JWT_REFRESH_TTL_SECONDS=2592000 # 30 day refresh token

# OAuth provider client IDs/secrets. Set redirect URI in each provider console
# to https://api.<domain>/auth/callback/{provider}.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Apple Sign-In (env-conditional: all four must be set to enable the real flow;
# when absent the /auth/exchange endpoint returns 501 with a clear message).
# APPLE_CLIENT_ID is the Services ID (e.g. com.example.app.web).
# APPLE_TEAM_ID is the 10-character Team ID from developer.apple.com.
# APPLE_KEY_ID is the Key ID of the Sign in with Apple private key.
# APPLE_PRIVATE_KEY is the ES256 private key in PEM format; escape newlines as \n
# when setting inline, or load from a secrets manager in production.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Geocoding cache (Nominatim reverse-geocode results stored in Redis).
GEOCODE_CACHE_TTL=2592000       # seconds — default 30 days

# Public base URLs — used by /auth/callback to compute redirect_uri and the
# post-auth redirect with access/refresh in the URL fragment.
API_BASE_URL=http://localhost:11008
WEB_APP_URL=http://localhost:11000

# Public base URL for serving stored avatars (CDN or MinIO/B2 host).
# Defaults to the MinIO endpoint scheme when unset.
MINIO_PUBLIC_URL=http://localhost:11900
