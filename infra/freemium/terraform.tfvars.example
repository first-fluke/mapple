project_prefix       = "globe-crm"
github_repo          = "first-fluke/mapple"
supabase_org_id      = ""
supabase_db_password = ""
supabase_region      = "ap-northeast-2"
upstash_region       = "ap-northeast-1"
b2_region            = "us-west-004"
api_url              = "https://globe-crm-api.fly.dev"
web_app_url          = "https://globe-crm.vercel.app"

# Cloudflare DNS — fill in after domain is registered and zone is added to Cloudflare.
# Required env var: CLOUDFLARE_API_TOKEN (Zone:Read + DNS:Edit scopes)
cloudflare_zone_name        = "" # TODO(external): e.g. "globecrm.io"
cloudflare_web_cname_target = "" # TODO(external): from Vercel project > Domains (e.g. "cname.vercel-dns.com")
cloudflare_api_cname_target = "" # TODO(external): from `flyctl info` (e.g. "globe-crm-api.fly.dev")
cloudflare_web_proxied      = true
cloudflare_api_proxied      = false
